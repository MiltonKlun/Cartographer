{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cartographer/behavior.schema.json",
  "title": "Behavior",
  "description": "A user-visible promise the product makes, stated as one falsifiable sentence (SPEC §3.1). confirmed_by absent ⇒ proposal (I3). Nothing is deleted: retirement keeps history (I11).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "statement", "area", "criticality", "links", "created_by", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^BHV-[0-9]{4,}$" },
    "statement": { "type": "string", "minLength": 8 },
    "area": { "type": "string", "minLength": 1 },
    "criticality": { "enum": ["red", "high", "normal", "low"] },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "demanded_by": { "type": "array", "items": { "type": "string" } },
        "verified_by": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["test_id", "confidence"],
            "properties": {
              "test_id": { "type": "string", "minLength": 1 },
              "confidence": { "enum": ["high", "medium", "low"] }
            }
          }
        },
        "implemented_in": { "type": "array", "items": { "type": "string" } },
        "violated_by": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confirmed_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["person", "at"],
      "properties": {
        "person": { "type": "string", "minLength": 1 },
        "at": { "$ref": "#/definitions/timestamp" }
      }
    },
    "created_by": { "enum": ["ingest:ci", "interview", "session", "import", "manual"] },
    "status": { "enum": ["active", "retired"] },
    "merged_into": { "type": "string", "pattern": "^BHV-[0-9]{4,}$" },
    "notes": { "type": "string" }
  },
  "definitions": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
    }
  }
}
