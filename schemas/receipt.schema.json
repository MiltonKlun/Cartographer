{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cartographer/receipt.schema.json",
  "title": "Action receipt",
  "description": "Immutable record of any autonomous action: what, why, evidence basis, how to revert (SPEC §3.5). An ACT-tier action without a receipt did not happen (I4, I11).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "class", "target", "summary", "evidence_basis", "revert", "performed_at", "performed_by"],
  "properties": {
    "id": { "type": "string", "pattern": "^ACT-[0-9]{4,}$" },
    "class": {
      "enum": ["selector_heal", "flake_quarantine", "flake_ticket", "pr_comment", "verdict_recompute", "evidence_ingest", "export", "vault_gc"]
    },
    "target": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "evidence_basis": { "type": "array", "items": { "type": "string" } },
    "revert": { "type": "string", "minLength": 1 },
    "performed_at": { "$ref": "#/definitions/timestamp" },
    "performed_by": { "type": "string", "minLength": 1 }
  },
  "definitions": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
    }
  }
}
