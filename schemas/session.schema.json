{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cartographer/session.schema.json",
  "title": "Session",
  "description": "A ride-along recording of human exploratory testing (SPEC §3.4). Nothing merges without human review (I8/I3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "engineer", "started_at", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^SES-[0-9]{4,}$" },
    "engineer": { "type": "string", "minLength": 1 },
    "started_at": { "$ref": "#/definitions/timestamp" },
    "ended_at": {
      "anyOf": [{ "$ref": "#/definitions/timestamp" }, { "type": "null" }]
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "note", "auto"],
        "properties": {
          "at": { "$ref": "#/definitions/timestamp" },
          "note": { "type": "string", "minLength": 1 },
          "auto": { "type": "boolean" },
          "evidence_id": { "type": "string", "pattern": "^EV-[0-9]{4,}$" }
        }
      }
    },
    "proposals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "behaviors": { "type": "array", "items": { "type": "string" } },
        "tests": { "type": "array", "items": { "type": "string" } },
        "questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "status": { "enum": ["open", "in_review", "merged", "discarded"] }
  },
  "definitions": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
    }
  }
}
