{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cartographer/question.schema.json",
  "title": "Question",
  "description": "Assistant-initiated request for human meaning, queued when the map has a gap (SPEC §3.3, I3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "behavior_id", "prompt", "why_asked", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^Q-[0-9]{4,}$" },
    "behavior_id": {
      "anyOf": [
        { "type": "string", "pattern": "^BHV-[0-9]{4,}$" },
        { "type": "null" }
      ]
    },
    "prompt": { "type": "string", "minLength": 1 },
    "why_asked": { "type": "string", "minLength": 1 },
    "status": { "enum": ["open", "answered", "dismissed"] },
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by", "at", "text"],
      "properties": {
        "by": { "type": "string", "minLength": 1 },
        "at": { "$ref": "#/definitions/timestamp" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "resulting_mutations": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
    }
  }
}
