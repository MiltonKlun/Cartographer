{
  "name": "cartographer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "QA behavior ledger — the map, not the pipeline",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "cart": "./bin/cart.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs",
    "pretest": "npm run build",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --test \"dist/test/unit/**/*.test.js\"",
    "test:integration": "node --test \"dist/test/integration/**/*.test.js\"",
    "test:e2e": "node --test \"dist/test/e2e/**/*.test.js\"",
    "validate:schemas": "node scripts/validate-schemas.mjs",
    "check": "npm run typecheck && npm run lint && npm run test && npm run validate:schemas"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
